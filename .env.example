MONTRUST_BASE_URL=https://montrust-monad-blitz-pune.vercel.app
# Exposed to browser for SSR fallback on /register (optional on localhost)
NEXT_PUBLIC_MONTRUST_BASE_URL=https://montrust-monad-blitz-pune.vercel.app

# Use production URL when updating on-chain agent card:
# MONTRUST_BASE_URL=https://montrust-monad-blitz-pune.vercel.app npm run update:agent-uri -- 1786

# NVIDIA NIM — MiniMax-M3 vision (https://build.nvidia.com/minimaxai/minimax-m3)
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_VISION_MODEL=minimaxai/minimax-m3
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_MAX_TOKENS=128
NVIDIA_TEMPERATURE=0.2
NVIDIA_TOP_P=0.95
DEPLOYER_PRIVATE_KEY=0x-your-private-key-here
# Monad testnet seller address for x402 MON payouts (defaults to deployer)
X402_SELLER_ADDRESS=0xda49D74234318880a2b6af6BF76B390A55284e73
# Native MON amount per x402 request on testnet (default 0.1)
X402_PAYMENT_AMOUNT_MON=0.1